{
    "name": "solar_energy_knowledge_graph",
    "strict": true,
    "schema": {
        "type": "object",

        "properties": {

            "article_id": {
                "type": "string"
            },

            "publication_date": {
                "type": "string"
            },

            "source": {
                "type": "string"
            },

            "unrelated": {
                "type": "boolean"
            },

            "nodes": {

                "type": "array",

                "items": {

                    "type": "object",

                    "properties": {

                        "id": {
                            "type": "string"
                        },

                        "type": {

                            "type": "string",

                            "enum": [
                                "Company",
                                "GovernmentAgency",
                                "Organization",
                                "Policy",
                                "Technology",
                                "Project",
                                "Location",
                                "Person"
                            ]

                        },

                        "properties": {

                            "type": "object",

                            "properties": {

                                "name": {
                                    "type": "string"
                                },

                                "ticker": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "headquarters": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "country": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "government_level": {

                                    "type": [
                                        "string",
                                        "null"
                                    ],

                                    "enum": [
                                        "federal",
                                        "state",
                                        "local",
                                        null
                                    ]

                                },

                                "organization_type": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "policy_type": {

                                    "type": [
                                        "string",
                                        "null"
                                    ],

                                    "enum": [

                                        "tax_credit",
                                        "legislation",
                                        "regulation",
                                        "subsidy",
                                        "grant",
                                        "tariff",
                                        "renewable_standard",
                                        "government_program",
                                        null

                                    ]

                                },

                                "jurisdiction": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "enactment_year": {
                                    "type": [
                                        "integer",
                                        "null"
                                    ]
                                },

                                "capacity": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "location": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "time_period": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                },

                                "location_type": {

                                    "type": [
                                        "string",
                                        "null"
                                    ],

                                    "enum": [
                                        "country",
                                        "state",
                                        "city",
                                        "region",
                                        null
                                    ]

                                },

                                "role_in_solar_energy_space": {
                                    "type": [
                                        "string",
                                        "null"
                                    ]
                                }

                            },

                            "required": [

                                "name",
                                "ticker",
                                "headquarters",
                                "country",
                                "government_level",
                                "organization_type",
                                "policy_type",
                                "jurisdiction",
                                "enactment_year",
                                "capacity",
                                "location",
                                "time_period",
                                "location_type",
                                "role_in_solar_energy_space"

                            ],

                            "additionalProperties": false

                        },

                        "mentions": {

                            "type": "array",

                            "items": {
                                "type": "string"
                            }

                        }

                    },

                    "required": [

                        "id",
                        "type",
                        "properties",
                        "mentions"

                    ],

                    "additionalProperties": false

                }

            },


            "edges": {

                "type": "array",

                "items": {

                    "type": "object",

                    "properties": {

                        "source": {
                            "type": "string"
                        },

                        "target": {
                            "type": "string"
                        },


                        "relationship": {

                            "type": "string",

                            "enum": [

                                "PARTNERS_WITH",
                                "ACQUIRES",
                                "INVESTS_IN",
                                "OWNS",
                                "SUPPLIES",
                                "COMPETES_WITH",

                                "DEVELOPS",
                                "MANUFACTURES",
                                "USES",
                                "DEPLOYS",

                                "FUNDS",
                                "REGULATES",
                                "SUBSIDIZES",
                                "APPROVES",

                                "BUILDS",
                                "OPERATES",
                                "LOCATED_IN",

                                "ANNOUNCES",
                                "REPORTS",

                                "PREDICTS"

                            ]

                        },


                        "article_id": {
                            "type": "string"
                        },


                        "publication_date": {
                            "type": "string"
                        },


                        "year": {
                            "type": "integer"
                        },


                        "source_name": {
                            "type": "string"
                        },


                        "confidence": {

                            "type": "number",

                            "minimum": 0,

                            "maximum": 1

                        },


                        "evidence": {
                            "type": "string"
                        },


                        "temporal_qualifier": {

                            "type": [
                                "string",
                                "null"
                            ]

                        },


                        "prediction_sentiment": {

                            "type": [
                                "string",
                                "null"
                            ],

                            "enum": [

                                "optimistic",
                                "neutral",
                                "pessimistic",
                                null

                            ]

                        }

                    },


                    "required": [

                        "source",
                        "target",
                        "relationship",
                        "article_id",
                        "publication_date",
                        "year",
                        "source_name",
                        "confidence",
                        "evidence",
                        "temporal_qualifier",
                        "prediction_sentiment"

                    ],

                    "additionalProperties": false

                }

            }

        },


        "required": [

            "article_id",
            "publication_date",
            "source",
            "unrelated",
            "nodes",
            "edges"

        ],

        "additionalProperties": false

    }
}



